# Amazon Ads API / Login with Amazon (LwA)
# Get these from Amazon Developer Console + Amazon Ads API application
LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxx
LWA_CLIENT_SECRET=your-client-secret
AMAZON_ADS_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxx

# OAuth redirect (must match Allowed Return URLs in LwA Web Settings)
OAUTH_REDIRECT_URI=https://localhost:3000/auth/callback
BASE_URL=https://localhost:3000

# Region: NA | EU | FE
REGION=NA

# Token encryption (32-byte hex for AES-256)
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-key-here-use-openssl-rand-hex-32

# Session secret
SESSION_SECRET=your-session-secret-min-32-chars

# DB path (SQLite)
DB_PATH=./data/app.db
